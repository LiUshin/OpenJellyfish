# ── LiveKit 语音 Worker 环境变量 ──────────────────────────────────
# 连接 SFU 并注册为 agent worker
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# OpenJellyfish Core 内网基址(Worker → Core 引导/委派)
JELLYFISH_API_BASE=http://localhost:8000

# 注:不需要 VOICE_BRIDGE_SECRET。桥接令牌由 Core 签发并校验,Worker 只从参与者
# metadata 读出后原样透传给 Core,自己既不签也不验,故无需持有该密钥。
