# ============================================================
# JellyfishBot 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- Provider 默认配置（至少配置一个 API Key） ----

# Anthropic（LLM 对话）
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=                     # 留空 = https://api.anthropic.com

# OpenAI（LLM 对话 + 图片/语音/视频生成 + 实时语音 + 语音转写）
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=                        # 留空 = https://api.openai.com/v1

# ---- 按能力可选覆盖（不填则使用上面的 OPENAI_* 默认值） ----

# 图片生成（gpt-image-2）
# IMAGE_API_KEY=
# IMAGE_BASE_URL=

# TTS 语音生成（tts-1）
# TTS_API_KEY=
# TTS_BASE_URL=

# 视频生成（sora-2）
# VIDEO_API_KEY=
# VIDEO_BASE_URL=

# 实时语音对话（gpt-4o-realtime）
# S2S_API_KEY=
# S2S_BASE_URL=

# 语音转写（whisper-1）
# STT_API_KEY=
# STT_BASE_URL=

# ---- 联网工具（二选一或同时配置） ----

# CloudsWay 搜索 API（自有服务，优先使用）
# CLOUDSWAY_SEARCH_KEY=
# CLOUDSWAY_READ_URL=https://searchapi.cloudsway.net/search/<read_id>/read
# CLOUDSWAY_SEARCH_URL=https://searchapi.cloudsway.net/search/<search_id>/smart

# Tavily 搜索 API（备选，CLOUDSWAY_SEARCH_KEY 未设置时使用）
# TAVILY_API_KEY=tvly-xxxxx

# ---- 可选配置 ----

# Langfuse 可观测性
# LANGFUSE_SECRET_KEY=sk-lf-xxxxx
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# LangChain 追踪
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxx
# LANGCHAIN_PROJECT=jellyfishbot

# 服务配置
# UVICORN_WORKERS=1
# LOG_LEVEL=info

# ---- 文件存储后端（可选，默认 local） ----
# STORAGE_BACKEND=local              # local | s3
# S3_BUCKET=jellyfishbot-files
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=                   # 留空 = AWS S3，填自定义端点 = MinIO/R2/OSS
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=                         # 可选全局键前缀

# 端口映射 (docker-compose)
# FRONTEND_PORT=3030
# API_PORT=3033
