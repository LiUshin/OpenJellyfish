# ============================================================
# OpenJellyfish 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 实例卡死 / SSH 连不上时的最小恢复（部署在宿主机 .env，重建容器生效）----
# 设为 1 时本进程强制：不调度定时任务 + 不批量 pip 恢复 venv（先让 CPU/内存降下来）
# SAFE_STARTUP=1
# 仍需手工关容器时可：sudo systemctl stop docker
# 详见 main.py::_apply_safe_startup

# ---- Provider 默认配置（至少配置一个 API Key） ----

# Anthropic（LLM 对话）
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=                     # 留空 = https://api.anthropic.com

# OpenAI（LLM 对话 + 图片/语音/视频生成 + 实时语音 + 语音转写）
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=                        # 留空 = https://api.openai.com/v1

# ---- 按能力可选覆盖（不填则使用上面的 OPENAI_* 默认值） ----

# 图片生成（gpt-image-2）
# IMAGE_API_KEY=
# IMAGE_BASE_URL=

# TTS 语音生成（tts-1）
# TTS_API_KEY=
# TTS_BASE_URL=

# 视频生成（sora-2）
# VIDEO_API_KEY=
# VIDEO_BASE_URL=

# 实时语音对话（gpt-4o-realtime）
# S2S_API_KEY=
# S2S_BASE_URL=

# 语音转写（whisper-1）
# STT_API_KEY=
# STT_BASE_URL=

# ---- 联网工具（二选一或同时配置） ----

# CloudsWay 搜索 API（自有服务，优先使用）
# CLOUDSWAY_SEARCH_KEY=
# CLOUDSWAY_READ_URL=https://searchapi.cloudsway.net/search/<read_id>/read
# CLOUDSWAY_SEARCH_URL=https://searchapi.cloudsway.net/search/<search_id>/smart

# Tavily 搜索 API（备选，CLOUDSWAY_SEARCH_KEY 未设置时使用）
# TAVILY_API_KEY=tvly-xxxxx

# ---- 可选配置 ----

# Langfuse 可观测性
# LANGFUSE_SECRET_KEY=sk-lf-xxxxx
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# LangChain 追踪
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxx
# LANGCHAIN_PROJECT=openjellyfish

# 服务配置
# UVICORN_WORKERS=1
# LOG_LEVEL=info

# ---- 定时任务调度器（OOM 防护）----
# 设为 1/true/yes/on 时跳过 HeapScheduler.start()（仅救火；编排 API 仍在，但不会自动按期执行）
# DISABLE_SCHEDULER=
# 同时处于执行中的定时任务上限（每条 agent 约 100–300MB）；4GB 机器建议 2～4，8GB 可 6～8
# SCHEDULER_MAX_CONCURRENT=4

# ---- 启动时用户 venv 恢复（CPU 防护）----
# 若设为 0/false/no/off，则跳过「扫描 users/*/venv/requirements.txt 并 pip install -r」（启动瞬间更轻）
# RESTORE_VENVS_ON_STARTUP=
# 有 requirements.txt 的用户之间，最多几人并行 pip（默认 1=顺序执行，避免多用户同时 pip 把 CPU 打满）
# RESTORE_VENVS_CONCURRENCY=1

# ---- 文件存储后端（可选，默认 local） ----
# STORAGE_BACKEND=local              # local | s3
# S3_BUCKET=openjellyfish-files
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=                   # 留空 = AWS S3，填自定义端点 = MinIO/R2/OSS
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PREFIX=                         # 可选全局键前缀

# 端口映射 (docker-compose)
# FRONTEND_PORT=3030
# API_PORT=3033

# ---- LiveKit 实时语音插件（可选）----
# 启用语音前台时配置。详见 plugins/voice/README.md 与 docker-compose.voice.yml。
#
# LIVEKIT_URL 是「浏览器」要连接的 SFU 地址，必须是浏览器可达的公网地址。
# 切勿用 localhost —— localhost 指浏览器所在的机器（你本地电脑），不是 EC2！
#   · 通过 http://<EC2公网IP> 访问前端：LIVEKIT_URL=ws://<EC2公网IP>:7880
#   · 通过 https://<域名> 访问前端：需用 wss（经 nginx 反代到 7880），
#     例如 LIVEKIT_URL=wss://<域名>/livekit （否则浏览器拦截 ws 混合内容）
# LIVEKIT_URL=ws://<EC2公网IP>:7880
# 与 livekit-server keys 一致（见 livekit/livekit.yaml，默认 devkey/secret）。
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
# Core 与语音 Worker 共享的桥接令牌密钥（务必改成强随机值，二者必须一致）。
# VOICE_BRIDGE_SECRET=change-me-shared-with-core

# ---- Fish Audio TTS / STT（可选，语音前台调音台里选 fishaudio 时启用）----
# 从 https://fish.audio 控制台获取 API Key；TTS 与 STT 共用同一把 key。
# 注意：Fish 的 STT(/v1/asr) 是批量识别（非流式），延迟高于流式 STT。
# FISH_API_KEY=
# FISH_REFERENCE_ID=                        # TTS 音色模型 ID，留空用 Fish 通用音色
# FISH_MODEL=s1                             # TTS 模型：s1 / s2-pro
# FISH_BASE_URL=                            # 可选，默认 https://api.fish.audio

# ---- 阿里云 DashScope（可选，语音前台 STT=Paraformer / TTS=CosyVoice 时启用）----
# 从 https://bailian.console.aliyun.com 控制台获取 API Key（流式、端点在国内；STT/TTS 共用同一把 key）。
# DASHSCOPE_API_KEY=

# ---- 语音前台 LLM 用 Bedrock（可选）----
# 复用主 agent 的 Bedrock API Key（设置页 → Bedrock，无需额外环境变量）；
# 在调音台把「前台 LLM 供应商」选 Bedrock，模型填 claude-sonnet-4-6 等短名即可。
