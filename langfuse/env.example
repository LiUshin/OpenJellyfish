# ============================================================
# Langfuse 自托管环境变量
#
# 使用方式: cp env.example .env 然后修改下面的值
#
# 生成密钥命令:
#   openssl rand -hex 16    → 用于 SALT
#   openssl rand -hex 32    → 用于 ENCRYPTION_KEY
#   openssl rand -base64 32 → 用于 NEXTAUTH_SECRET
# ============================================================

# ==================== 必须修改 ====================

# 你的 Langfuse 域名 (配合 Nginx 反代使用)
NEXTAUTH_URL=https://langfuse.easybanker.ai

# 认证加密密钥
NEXTAUTH_SECRET=changeme_run_openssl_rand_base64_32
SALT=changeme_run_openssl_rand_hex_16
ENCRYPTION_KEY=changeme_run_openssl_rand_hex_32

# PostgreSQL 密码
POSTGRES_PASSWORD=changeme_strong_postgres_password

# ClickHouse 密码
CLICKHOUSE_PASSWORD=changeme_strong_clickhouse_password

# Redis 密码
REDIS_AUTH=changeme_strong_redis_password

# MinIO 密码
MINIO_ROOT_PASSWORD=changeme_strong_minio_password

# MinIO 访问密钥 (保持与 MINIO_ROOT_PASSWORD 一致或单独设置)
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=changeme_strong_minio_password
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=changeme_strong_minio_password
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=changeme_strong_minio_password

# ==================== 可选配置 ====================

# Langfuse Web 端口 (默认 3000)
LANGFUSE_PORT=3000

# 遥测 (发送匿名使用数据给 Langfuse 团队)
TELEMETRY_ENABLED=false

# 数据库连接 (默认使用 docker-compose 内部的 postgres)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgres:5432/postgres

# ==================== 自动初始化 (可选) ====================
# 首次启动时自动创建组织/项目/管理员
# 设置后无需手动在 Dashboard 注册

# LANGFUSE_INIT_ORG_NAME=MyOrg
# LANGFUSE_INIT_PROJECT_NAME=JellyfishBot
# LANGFUSE_INIT_USER_EMAIL=admin@yourdomain.com
# LANGFUSE_INIT_USER_NAME=Admin
# LANGFUSE_INIT_USER_PASSWORD=changeme_admin_password
