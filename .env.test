# ============================================================
# JellyfishBot 测试环境配置
# 用于本地 e2e 测试：iLink Mock + 6 场景联调
#
# 使用方法：
#   1. 复制到 .env 或通过 --env-file 加载
#   2. 启动 Mock: python tests/ilink_mock_server.py
#   3. 启动 App:  python -m uvicorn app.main:app --port 8000
#   4. 运行测试: python tests/test_e2e_local.py
# ============================================================

# ---- iLink Mock 指向 ----
ILINK_BASE_URL=http://localhost:9999
ILINK_CDN_URL=http://localhost:9999/cdn

# ---- LLM API（至少配置一个） ----
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=

# ---- 测试脚本配置 ----
APP_BASE_URL=http://localhost:8000
MOCK_BASE_URL=http://localhost:9999

# 注册密钥（如果 app 需要 reg_key 才能注册）
# REG_KEY=

# ---- 可选：语音转写（场景涉及语音时需要） ----
# STT_API_KEY=
# STT_BASE_URL=
