  "image": [
    {"id": "openai:gpt-image-1", "provider": "openai", "display_name": "GPT-Image-1",
     "default_params": {"size": "1024x1024", "quality": "auto"},
     "params_schema": {
       "size":    {"type": "enum", "options": ["1024x1024", "1536x1024", "1024x1536", "auto"]},
       "quality": {"type": "enum", "options": ["low", "medium", "high", "auto"]}
     }}
  ],

  "tts": [
    {"id": "openai:tts-1",    "provider": "openai", "display_name": "OpenAI TTS-1",
     "default_params": {"voice": "alloy", "speed": 1.0, "response_format": "mp3"},
     "params_schema": {
       "voice": {"type": "enum", "options": ["alloy", "echo", "fable", "onyx", "nova", "shimmer"]},
       "speed": {"type": "number", "min": 0.25, "max": 4.0}
     }},
    {"id": "openai:tts-1-hd", "provider": "openai", "display_name": "OpenAI TTS-1 HD",
     "default_params": {"voice": "alloy", "speed": 1.0, "response_format": "mp3"}},
    {"id": "minimax:speech-02-hd", "provider": "minimax", "display_name": "MiniMax Speech-02 HD",
     "default_params": {"voice": "male-qn-qingse", "speed": 1.0, "response_format": "mp3"},
     "params_schema": {
       "voice":   {"type": "string", "hint": "MiniMax voice_id，如 male-qn-qingse / female-shaonv / Calm_Woman"},
       "speed":   {"type": "number", "min": 0.5, "max": 2.0},
       "vol":     {"type": "number", "min": 0.0, "max": 10.0, "extras": true},
       "emotion": {"type": "enum", "options": ["happy", "sad", "angry", "fearful", "disgusted", "surprised", "neutral"], "extras": true},
       "sample_rate": {"type": "enum", "options": [8000, 16000, 22050, 24000, 32000, 44100], "extras": true}
     }},
    {"id": "minimax:speech-02-turbo", "provider": "minimax", "display_name": "MiniMax Speech-02 Turbo",
     "default_params": {"voice": "male-qn-qingse", "speed": 1.0, "response_format": "mp3"}}
  ],

  "video": [
    {"id": "openai:sora-2-2025-12-08", "provider": "openai", "display_name": "Sora 2",
     "default_params": {"seconds": 4, "size": "1280x720"},
     "params_schema": {
       "seconds": {"type": "enum", "options": [4, 8, 12]},
       "size":    {"type": "enum", "options": ["1280x720", "720x1280"]}
     }},
    {"id": "minimax:MiniMax-Hailuo-02", "provider": "minimax", "display_name": "MiniMax Hailuo-02",
     "default_params": {"seconds": 6, "size": "1280x720"},
     "params_schema": {
       "seconds": {"type": "enum", "options": [6, 10]},
       "size":    {"type": "enum", "options": ["1280x720", "720x1280", "1920x1080"]},
       "prompt_optimizer": {"type": "boolean", "extras": true}
     }}
  ],

  "stt": [
    {"id": "openai:whisper-1", "provider": "openai", "display_name": "Whisper",
     "default_params": {"language": null}}
  ],

  "s2s": [
    {"id": "openai:gpt-4o-realtime-preview", "provider": "openai", "display_name": "GPT-4o Realtime"}
  ]
}
